# Environment Variables - Copy this to .env and fill in your values
OPENAI_API_KEY=sk-your-openai-key-here
# Custom OpenAI-compatible host (or full URL). Becomes https://host/v1
# URL_ENDPOINT=
# Optional full base URL override (takes precedence over URL_ENDPOINT)
# ANTHROPIC_API_KEY=sk-ant-your-anthropic-key-here
LLM_PROVIDER=openai
LLM_MODEL=gemini-2.5-flash
LLM_MINI_MODEL=gemini-2.5-flash
REDIS_URL=redis://localhost:6379
CHROMA_PERSIST_DIR=./data/chroma_db
LOG_LEVEL=INFO
